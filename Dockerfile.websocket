# ============================================================
# Dockerfile.websocket  —  Voice Survey WebSocket Server
# Multi-stage build: deps → builder → runner
# ============================================================

# ── Stage 1: base ────────────────────────────────────────────
FROM node:22-alpine AS base

RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@10.10.0


# ── Stage 2: deps ─────────────────────────────────────────────
FROM base AS deps

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile


# ── Stage 3: builder ──────────────────────────────────────────
# Compile the TypeScript websocket server.
# The websocket/tsconfig.json outputs to dist/websocket/
# with rootDir set to the project root, so @/* path aliases resolve.
FROM base AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN pnpm websocket:build


# ── Stage 4: runner ───────────────────────────────────────────
FROM node:22-alpine AS runner

RUN apk add --no-cache libc6-compat

WORKDIR /app

ENV NODE_ENV=production

# ── Runtime placeholders ──────────────────────────────────────
# ECS injects real values from SSM at runtime, overriding these.
# They exist so lib/env.ts doesn't throw 'Missing required env var'
# since multi-stage builds don't carry ENV vars from builder to runner.
ENV DATABASE_URL="postgresql://placeholder:5432/db"
ENV BETTER_AUTH_SECRET="placeholder_secret"
ENV BETTER_AUTH_URL="http://localhost:3000"
ENV GOOGLE_CLIENT_ID="placeholder_id"
ENV GOOGLE_CLIENT_SECRET="placeholder_secret"
ENV RESEND_API_KEY="re_placeholder"
ENV RESEND_FROM_EMAIL="onboarding@resend.dev"
ENV GOOGLE_GENERATIVE_AI_API_KEY="placeholder_key"
ENV OPENAI_API_KEY="placeholder_key"
ENV UPSTASH_REDIS_REST_URL="https://placeholder.upstash.io"
ENV UPSTASH_REDIS_REST_TOKEN="placeholder_token"
ENV NEXT_PUBLIC_SUPABASE_URL="https://placeholder.supabase.co"
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="pk_placeholder"
ENV convy_supabase_secret_key="placeholder_key"
ENV REDIS_URL="redis://localhost:6379"
ENV APP_BASE_URL="http://localhost:3000"
ENV ADMIN_EMAILS=""

# Security: run as non-root.
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 wsuser

# Only copy what the compiled server needs at runtime.
COPY --from=builder --chown=wsuser:nodejs /app/dist ./dist
COPY --from=builder --chown=wsuser:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=wsuser:nodejs /app/package.json ./
# Agent instructions (skills)
COPY --from=builder --chown=wsuser:nodejs /app/.agent/skills ./.agent/skills

USER wsuser

EXPOSE 3001

# Health check — polls the /health HTTP endpoint built into the WS server.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD wget -qO- http://localhost:3001/health || exit 1

CMD ["node", "dist/websocket/server.js"]
