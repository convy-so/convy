# ============================================================
# Dockerfile.workers  —  BullMQ Background Workers
# 6 workers: conversation-insights, survey-analytics,
#            sample-conversation-insights, email,
#            pattern-extraction, experiment-evaluation
# Multi-stage build: deps → builder → runner
# ============================================================

# ── Stage 1: base ────────────────────────────────────────────
FROM node:22-alpine AS base

RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@10.10.0


# ── Stage 2: deps ─────────────────────────────────────────────
FROM base AS deps

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile


# ── Stage 3: builder ──────────────────────────────────────────
# Compile the TypeScript workers.
# workers/tsconfig.json outputs to dist/workers/ using CommonJS.
FROM base AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN pnpm workers:build


# ── Stage 4: runner ───────────────────────────────────────────
FROM node:22-alpine AS runner

RUN apk add --no-cache libc6-compat

WORKDIR /app

ENV NODE_ENV=production
ENV NODE_OPTIONS="--dns-result-order=ipv4first"

# ── Runtime placeholders ──────────────────────────────────────
# ECS injects real values from SSM at runtime, overriding these.
# They exist so lib/env.ts doesn't throw 'Missing required env var'
# since multi-stage builds don't carry ENV vars from builder to runner.
ENV DATABASE_URL="postgresql://placeholder:5432/db"
ENV BETTER_AUTH_SECRET="placeholder_secret"
ENV BETTER_AUTH_URL="http://localhost:3000"
ENV GOOGLE_CLIENT_ID="placeholder_id"
ENV GOOGLE_CLIENT_SECRET="placeholder_secret"
ENV RESEND_API_KEY="re_placeholder"
ENV RESEND_FROM_EMAIL="onboarding@resend.dev"
ENV GOOGLE_GENERATIVE_AI_API_KEY="placeholder_key"
ENV OPENAI_API_KEY="placeholder_key"
ENV UPSTASH_REDIS_REST_URL="https://placeholder.upstash.io"
ENV UPSTASH_REDIS_REST_TOKEN="placeholder_token"
ENV NEXT_PUBLIC_SUPABASE_URL="https://placeholder.supabase.co"
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="pk_placeholder"
ENV convy_supabase_secret_key="placeholder_key"
ENV REDIS_URL="redis://localhost:6379"
ENV APP_BASE_URL="http://localhost:3000"
ENV ADMIN_EMAILS=""


# Security: non-root user.
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 worker

COPY --from=builder --chown=worker:nodejs /app ./
USER worker

# Workers don't listen on any port — they connect OUT to Redis.
# No EXPOSE or HEALTHCHECK via HTTP port.
# ECS monitors the container's process exit code instead.

CMD ["./node_modules/.bin/tsx", "workers/index.ts"]
