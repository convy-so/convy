# ============================================================
# .env.example  —  Template for environment variables
# Copy this to .env for local development.
# NEVER commit actual values to Git.
# ============================================================

# Set staging and production values in your platform's secret manager.

# ── Database ──────────────────────────────────────────────────
# Use separate databases for Dev, Staging, and Production.
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_DIRECT_URL="postgresql://user:password@db.host:5432/dbname"

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="https://yourdomain.com" # e.g., staging.yourdomain.com

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="convy@yourdomain.com"

# ── Media Retrieval Pipelines ─────────────────────────────────
TAVILY_API_KEY=""
YOUTUBE_DATA_API_KEY=""

# ── AI Models ─────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CLOUD_PROJECT_ID=""
OPENAI_API_KEY=""
DEEPGRAM_API_KEY=""
GDPR_EU_MODE="false"
NEXT_PUBLIC_GDPR_EU_MODE="false"
GDPR_PRIVACY_SECRET=""
GDPR_EU_APPROVED_PROCESSORS="supabase,resend"

# ── Redis ─────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
REDIS_URL="redis://localhost:6379"
# Set true only for local/dev environments with self-signed certs.
ALLOW_INSECURE_TLS="false"

# ── Upstash (rate limiting only) ──────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
convy_supabase_secret_key=""

# ── Application ───────────────────────────────────────────────
APP_BASE_URL="https://yourdomain.com"
NEXT_PUBLIC_WEBSOCKET_URL="wss://yourdomain.com"
WEBSOCKET_PORT="3001"
VOICE_AGENT_INTERNAL_KEY="change-me-in-production"


# ── Admin ─────────────────────────────────────────────────────

NODE_ENV="production"

# ── Sentry Monitoring ─────────────────────────────────────────
# Use separate Sentry projects for Staging and Production if preferred.
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

SENTRY_NODE_DSN=""

OUTBOX_RELAY_ENABLED=true
