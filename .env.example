# ============================================================
# .env.example  —  Template for environment variables
# Copy this to .env (local dev) or .env.docker (docker compose)
# NEVER commit actual values to Git.
# ============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="https://yourdomain.com"

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="convy@yourdomain.com"

# ── AI Models ─────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CLOUD_PROJECT_ID=""
OPENAI_API_KEY=""
DEEPGRAM_API_KEY=""

# ── Redis ─────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Docker compose: redis://redis:6379
# Production (ElastiCache): redis://convy-redis.xxxx.cache.amazonaws.com:6379
REDIS_URL="redis://localhost:6379"

# ── Upstash (rate limiting only) ──────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
convy_supabase_secret_key=""

# ── Application ───────────────────────────────────────────────
APP_BASE_URL="https://yourdomain.com"
NEXT_PUBLIC_WEBSOCKET_URL="wss://yourdomain.com"
WEBSOCKET_PORT="3001"


# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAILS="admin@yourdomain.com"

NODE_ENV="production"

# ── Sentry Monitoring ─────────────────────────────────────────
# Project 1: Next.js
SENTRY_DSN=""
# Required for build-time source map upload
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Project 2: Node Services (Websocket & Workers)
SENTRY_NODE_DSN=""
