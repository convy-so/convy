# ==============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ==============================================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/convy

# Authentication (Better Auth)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (for user authentication)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# AI (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Redis (Local - for Background Jobs & Websockets)
REDIS_URL=redis://localhost:6379

# Redis (Upstash - for Rate Limiting & Caching)
UPSTASH_REDIS_URL=redis://default:password@your-upstash-url:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Supabase (for file storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# OpenAI (required for some features)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# VOICE FEATURES - Required for voice survey functionality
# ==============================================================================

# Deepgram API Key (Required for Voice Features)
# Sign up at https://console.deepgram.com/signup for an API Key
DEEPGRAM_API_KEY=your-deepgram-api-key

# Voice Feature Configuration
ENABLE_VOICE_FEATURES=true
WEBSOCKET_PORT=3001

# Voice Processing Settings (optional, defaults shown)
VAD_SENSITIVITY=0.5
MAX_AUDIO_DURATION_MS=300000

# ==============================================================================
# OPTIONAL INTEGRATIONS
# ==============================================================================

# Notion Integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# Slack Integration
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:3000/api/slack/callback

# Token Encryption (for OAuth tokens)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
