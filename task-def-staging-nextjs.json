{
  "family": "convy-staging-nextjs",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::290368114395:role/convy-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::290368114395:role/convy-ecs-task-role",
  "containerDefinitions": [{
    "name": "nextjs",
    "image": "290368114395.dkr.ecr.eu-north-1.amazonaws.com/convy/nextjs:staging",
    "portMappings": [{ "containerPort": 3000, "hostPort": 3000, "protocol": "tcp" }],
    "essential": true,
    "environment": [
      { "name": "NODE_ENV", "value": "production" },
      { "name": "PORT", "value": "3000" }
    ],
    "secrets": [
      { "name": "DATABASE_URL",                         "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/DATABASE_URL" },
      { "name": "BETTER_AUTH_SECRET",                   "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/BETTER_AUTH_SECRET" },
      { "name": "BETTER_AUTH_URL",                      "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/BETTER_AUTH_URL" },
      { "name": "APP_BASE_URL",                         "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/APP_BASE_URL" },
      { "name": "NEXT_PUBLIC_WEBSOCKET_URL",            "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/NEXT_PUBLIC_WEBSOCKET_URL" },
      { "name": "NEXT_PUBLIC_SUPABASE_URL",             "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/NEXT_PUBLIC_SUPABASE_URL" },
      { "name": "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY", "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY" },
      { "name": "convy_supabase_secret_key",            "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/convy_supabase_secret_key" },
      { "name": "OPENAI_API_KEY",                       "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/OPENAI_API_KEY" },
      { "name": "GOOGLE_GENERATIVE_AI_API_KEY",         "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/GOOGLE_GENERATIVE_AI_API_KEY" },
      { "name": "RESEND_API_KEY",                       "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/RESEND_API_KEY" },
      { "name": "RESEND_FROM_EMAIL",                    "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/RESEND_FROM_EMAIL" },
      { "name": "UPSTASH_REDIS_REST_URL",               "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/UPSTASH_REDIS_REST_URL" },
      { "name": "UPSTASH_REDIS_REST_TOKEN",             "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/UPSTASH_REDIS_REST_TOKEN" },
      { "name": "REDIS_URL",                            "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/REDIS_URL" },
      { "name": "ADMIN_EMAILS",                         "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/ADMIN_EMAILS" },
      { "name": "GOOGLE_CLIENT_ID",                     "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/GOOGLE_CLIENT_ID" },
      { "name": "GOOGLE_CLIENT_SECRET",                 "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/GOOGLE_CLIENT_SECRET" },
      { "name": "ADMIN_PASSWORD",                       "valueFrom": "arn:aws:ssm:eu-north-1:290368114395:parameter/convy/staging/ADMIN_PASSWORD" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/staging-nextjs",
        "awslogs-region": "eu-north-1",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
