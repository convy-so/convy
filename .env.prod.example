# Copy to .env.prod on the EC2 server (never commit .env.prod to git):
#   cp .env.prod.example .env.prod

# ── Database (Supabase session pooler, port 5432) ─────────────
# IMPORTANT: use session pooler port 5432, NOT 6543 (transaction pooler breaks migrations/DDL).
DATABASE_URL=postgresql://postgres.projectref:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_DIRECT_URL=postgresql://postgres:password@db.projectref.supabase.co:5432/postgres
ALLOW_INSECURE_TLS=true
# Migrations run automatically on deploy and container start (RUN_DB_MIGRATE=true)
# Legacy push-only sync — use only before first migration baseline exists:
# RUN_DB_PUSH=false

# ── Redis (use compose redis service on EC2) ──────────────────
REDIS_URL=redis://redis:6379

# ── App URLs (replace with your EC2 IP or domain) ───────────
APP_BASE_URL=http://44.207.198.43:3000
BETTER_AUTH_URL=http://44.207.198.43:3000
NEXT_PUBLIC_APP_URL=http://44.207.198.43:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://44.207.198.43:3000
NEXT_PUBLIC_WEBSOCKET_URL=ws://44.207.198.43:3001
WEBSOCKET_PORT=3001

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
VOICE_AGENT_INTERNAL_KEY=change-me-voice-internal-key

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=convy@yourdomain.com

# ── OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI / Voice ────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
VOYAGE_API_KEY=

# ── Supabase (media storage) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
convy_supabase_secret_key=

# ── Upstash (WebSocket rate limiting) ─────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Optional ──────────────────────────────────────────────────
OUTBOX_RELAY_ENABLED=true
NODE_ENV=production
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# ── Auto-sync agent (optional backup deploy on server) ────────
DEPLOY_BRANCH=prod2
DEPLOY_INTERVAL_SECONDS=300
REQUIRE_CI_PASS=true
GITHUB_REPOSITORY=convy-so/convy
GITHUB_DEPLOY_TOKEN=
COMPOSE_PROJECT_NAME=convy
DOCKER_IMAGE=ghcr.io/convy-so/convy:prod2
