{
  "name": "convy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "workers:dev": "tsx watch --env-file=.env shared/infra/workers/worker-runtime.ts",
    "workers:build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -p shared/infra/workers/tsconfig.json",
    "workers:start": "node dist/shared/infra/workers/worker-runtime.js",
    "websocket:dev": "tsx watch --env-file=.env shared/realtime/server.ts",
    "websocket:build": "tsc -p shared/realtime/tsconfig.json",
    "websocket:start": "node dist/shared/realtime/server.js",
    "dev:all": "pnpm exec concurrently \"pnpm dev\" \"pnpm workers:dev\" \"pnpm websocket:dev\"",
    "start:all": "pnpm exec concurrently -k \"pnpm start\" \"pnpm exec tsx shared/infra/workers/worker-runtime.ts\" \"pnpm exec tsx shared/realtime/server.ts\"",
    "db:diagnose": "tsx --env-file=.env scripts/db-diagnostics.ts",
    "admin:promote": "tsx --env-file=.env scripts/promote-admin.ts",
    "materials:cleanup-failed": "tsx --env-file=.env features/tutoring/scripts/cleanup-failed-lesson-materials.ts",
    "materials:prune-attempts": "tsx --env-file=.env features/tutoring/scripts/prune-lesson-material-upload-attempts.ts",
    "email:dev": "email dev --dir features/auth/email",
    "db:generate": "drizzle-kit generate",
    "db:generate:initial": "drizzle-kit generate --name initial_schema",
    "db:migrate": "tsx scripts/run-db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "audit:structure": "node scripts/audit-repo-structure.cjs structure",
    "audit:imports": "node scripts/audit-repo-structure.cjs imports",
    "audit:repo": "node scripts/audit-repo-structure.cjs all",
    "audit:cohesion": "tsx scripts/generate-cohesion-audit.ts"
  },
  "dependencies": {
    "@ai-sdk/deepgram": "^2.0.17",
