# Copy to .env.docker and fill in secrets before running:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build

# ── Self-hosted infra (included in compose) ───────────────────
POSTGRES_USER=convy
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=convy

DATABASE_URL=postgresql://convy:change-me-postgres-password@postgres:5432/convy
DATABASE_DIRECT_URL=postgresql://convy:change-me-postgres-password@postgres:5432/convy
REDIS_URL=redis://redis:6379

# ── App URLs (update for your AWS domain) ─────────────────────
APP_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001
WEBSOCKET_PORT=3001

# ── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
VOICE_AGENT_INTERNAL_KEY=change-me-voice-internal-key

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=convy@yourdomain.com

# ── OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI ────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ── Supabase (media storage — still required, external service) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
convy_supabase_secret_key=

# ── Upstash (optional — WebSocket rate limiting) ──────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional ──────────────────────────────────────────────────
OUTBOX_RELAY_ENABLED=true
RUN_DB_PUSH=false
NODE_ENV=production
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Auto-deploy (production server only) ───────────────────────
# Used by deploy-sync in docker-compose.prod.yml
DEPLOY_BRANCH=production
DEPLOY_INTERVAL_SECONDS=300
REQUIRE_CI_PASS=true
GITHUB_REPOSITORY=your-org/convy
# GitHub PAT with repo read + commit status read (fine-grained or classic)
GITHUB_DEPLOY_TOKEN=ghp_your_token
COMPOSE_PROJECT_NAME=convy

# ── AWS production example ────────────────────────────────────
# APP_BASE_URL=https://app.yourdomain.com
# BETTER_AUTH_URL=https://app.yourdomain.com
# NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
# NEXT_PUBLIC_BETTER_AUTH_URL=https://app.yourdomain.com
# NEXT_PUBLIC_WEBSOCKET_URL=wss://app.yourdomain.com:3001
#
# For managed AWS databases, point DATABASE_URL / REDIS_URL at RDS
# and ElastiCache instead of the compose postgres/redis services:
# DATABASE_URL=postgresql://user:pass@your-rds-endpoint:5432/convy
# REDIS_URL=redis://your-elasticache-endpoint:6379
# Then run only the app service:
#   docker compose --env-file .env.docker up app --build
